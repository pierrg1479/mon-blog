---
import BaseHead from '../../components/BaseHead.astro';
import HeaderEn from '../../components/HeaderEn.astro';
import FooterEn from '../../components/FooterEn.astro';
import { SITE_TITLE } from '../../consts';

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const alternates = [
	{ hreflang: 'en', href: new URL('/en/contact', siteUrl).href },
	{ hreflang: 'fr', href: new URL('/contact', siteUrl).href },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact - ${SITE_TITLE}`} description="Contact The Optimization Guy" alternates={alternates} />
	</head>
	<body>
		<HeaderEn />
		<main>
			<h1>💭 A question or an idea?</h1>
			<p>
				Want to react to an article, share your own automation or ask a question about your setup? Leave me a message via the form below.
			</p>

			<div class="tally-container">
				<iframe
					src="https://tally.so/embed/NprMzQ?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
					width="100%"
					height="1200"
					frameborder="0"
					marginheight="0"
					marginwidth="0"
					title="Contact">
				</iframe>
			</div>
		</main>
		<FooterEn />

		<!-- Google Tag Manager - Deferred loading for better performance -->
		<script is:inline>
			const loadGTM = () => {
				const gtmScript = document.createElement('script');
				gtmScript.async = true;
				gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-PTBBTWQV';
				document.head.appendChild(gtmScript);
				window.dataLayer = window.dataLayer || [];
				window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
			};
			if ('requestIdleCallback' in window) {
				requestIdleCallback(loadGTM, { timeout: 3000 });
			} else {
				setTimeout(loadGTM, 2000);
			}
		</script>
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PTBBTWQV" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
	</body>
</html>
<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: rgb(var(--gray-dark));
		font-size: 20px;
		line-height: 1.6;
	}
	h1 {
		font-size: 3rem;
		font-weight: 700;
		line-height: 1;
		margin-bottom: 0.5em;
		margin-top: 1em;
	}
	p {
		margin-bottom: 2em;
	}
	.tally-container {
		width: 100%;
	}
	.tally-container iframe {
		border: none;
	}
</style>
