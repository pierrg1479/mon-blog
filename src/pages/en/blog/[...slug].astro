---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPostEn from '../../../layouts/BlogPostEn.astro';
import { execSync } from 'node:child_process';
import path from 'node:path';

export const prerender = true;

// Mapping EN slug → FR slug for hreflang
const enToFrSlugMap: Record<string, string> = {
	'automating-ebike-charging-off-peak-hours': 'automatisation-recharge-velo-heures-creuses',
	'home-assistant-mistakes-to-avoid': 'home-assistant-erreurs-a-eviter',
	'smart-plugs-savings-automations': 'prises-connectees-economies-automatisations',
	'tado-review-2-years-gas-savings': 'tado-retour-2-ans-economies-gaz',
};

export const getGitLastUpdatedDate = (entryId: string) => {
	try {
		const basePath = path.join(process.cwd(), 'src', 'content', 'blog-en');
		const possibleFiles = [
			path.join(basePath, entryId),
			path.join(basePath, `${entryId}.md`),
			path.join(basePath, `${entryId}.mdx`),
		];

		for (const filePath of possibleFiles) {
			try {
				const isoDate = execSync(`git log -1 --format=%cI -- "${filePath}"`, {
					encoding: 'utf-8',
				}).trim();

				if (isoDate) {
					const parsedDate = new Date(isoDate);
					if (!Number.isNaN(parsedDate.getTime())) {
						return parsedDate;
					}
				}
			} catch {
				continue;
			}
		}
		return undefined;
	} catch (error) {
		console.error(`Git error for ${entryId}:`, error);
		return undefined;
	}
};

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog-en')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);
	const publishedPosts = allPosts.filter(({ data }) => data.draft !== true);

	const toAdjacentPost = (post: CollectionEntry<'blog-en'> | undefined) => {
		if (!post) return undefined;
		const slug = post.slug ?? post.id.replace(/\.mdx?$/, '');
		const heroImage =
			typeof post.data.heroImage === 'string'
				? post.data.heroImage
				: post.data.heroImage?.src;

		return {
			slug,
			title: post.data.title,
			h1: post.data.h1,
			pubDate: post.data.pubDate,
			heroImage,
		};
	};

	return allPosts.map((post) => {
		const slug = post.slug ?? post.id.replace(/\.mdx?$/, '');
		const gitUpdatedDate = getGitLastUpdatedDate(post.id);
		const updatedDate = gitUpdatedDate || post.data.updatedDate || post.data.pubDate;

		const publishedIndex = publishedPosts.findIndex((p) => p.id === post.id);
		const previousPost = publishedIndex >= 0 ? toAdjacentPost(publishedPosts[publishedIndex + 1]) : undefined;
		const nextPost = publishedIndex >= 0 ? toAdjacentPost(publishedPosts[publishedIndex - 1]) : undefined;

		return {
			params: { slug },
			props: {
				...post,
				previousPost,
				nextPost,
				frSlug: enToFrSlugMap[slug],
				data: {
					...post.data,
					updatedDate,
				},
			},
		};
	});
}

type Props = CollectionEntry<'blog-en'> & { previousPost?: any; nextPost?: any; frSlug?: string };

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPostEn
	{...post.data}
	previousPost={post.previousPost}
	nextPost={post.nextPost}
	frSlug={post.frSlug}
	content={post.body}
>
	<Content />
</BlogPostEn>
