		description: 'Surveillance and access: cameras, smart lock, keypad… to stay secure without turning home into a bunker.'
	},
	{
		id: 'buttons-fingerbot',
		title: '🖲️ Buttons & Fingerbot',
		items: buttons,
		description: 'Physical shortcuts: one click = one scene, and "fingers" to automate what wasn\'t.'
	},
	{
		id: 'cleaning-maintenance',
		title: '🧹 Cleaning & Maintenance',
		items: cleaning,
		description: 'Chores I delegate: mowing and vacuuming, with maximum autonomy.'
	},
	{
		id: 'multimedia',
		title: '🎬 Multimedia',
		items: multimedia,
		description: 'Music and TV in the living room: centralized control from Home Assistant (and some cool automations).'
	},
];

const siteUrlBase = Astro.site?.href ?? Astro.url.origin;
const alternates = [
	{ hreflang: 'en', href: new URL('/en/my-equipment/', siteUrlBase).href },
	{ hreflang: 'fr', href: new URL('/mon-materiel/', siteUrlBase).href },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="My Home Automation Equipment – The Optimization Guy"
			description="Complete list of the smart home equipment I use daily: cameras, sensors, connected heating, and my recommendations."
			alternates={alternates}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
	</head>
	<body>
		<HeaderEn />
		<section class="hero-split" aria-label="Intro">
			<div class="hero-split__grid">
				<figure class="hero-split__media">
					<Image
						src={heroImg}
						alt="My Home Assistant smart home equipment (installed and tested at home)"
						width={1200}
						height={900}
						loading="eager"
						fetchpriority="high"
						format="webp"
						quality={85}
						class="hero-split__image"
					/>
				</figure>

				<div class="hero-split__content">
					<p class="hero-split__kicker">
						Purchased, installed and tested
					</p>

					<h1 class="hero-split__title">
						My Smart Home Equipment
					</h1>

					<p class="hero-split__intro">
						Here is the smart home equipment I actually use at home with Home Assistant.
						Everything has been purchased by me, installed and tested over time. I started by
						optimizing heating, then equipped the home with Tapo devices, before progressively
						migrating to a more reliable Zigbee ecosystem.
					</p>

					<nav aria-label="Quick access" class="hero-split__nav">
						<ul class="hero-split__chips">
							<li><a href="#infrastructure" class="hero-split__chip">Infrastructure</a></li>
							<li><a href="#smart-plugs-switches" class="hero-split__chip">Smart Plugs & Switches</a></li>
							<li><a href="#sensors" class="hero-split__chip">Sensors</a></li>
							<li><a href="#heating" class="hero-split__chip">Heating</a></li>
							<li><a href="#security" class="hero-split__chip">Security</a></li>
							<li><a href="#buttons-fingerbot" class="hero-split__chip">Buttons & Fingerbot</a></li>
							<li><a href="#cleaning-maintenance" class="hero-split__chip">Cleaning</a></li>
							<li><a href="#multimedia" class="hero-split__chip">Multimedia</a></li>
						</ul>
					</nav>
				</div>
			</div>
		</section>
		<main class="equipment-main">
			<article class="equipment-page">
				{sections.map((section) => (
					<section id={section.id} class="equipment-section">
						<h2>{section.title}</h2>
						<p class="section-intro">
							{section.description}
						</p>
						<EquipmentTable equipment={section.items} />
					</section>
				))}
			</article>
		</main>
		<FooterEn />

		<!-- Google Tag Manager - Deferred loading for better performance -->
		<script is:inline>
			const loadGTM = () => {
				const gtmScript = document.createElement('script');
				gtmScript.async = true;
				gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-PTBBTWQV';
				document.head.appendChild(gtmScript);
				window.dataLayer = window.dataLayer || [];
				window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
			};
			if ('requestIdleCallback' in window) {
				requestIdleCallback(loadGTM, { timeout: 3000 });
			} else {
				setTimeout(loadGTM, 2000);
			}
		</script>
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PTBBTWQV" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
	</body>
</html>

<style is:global>
	:root {
		--equipment-max-width: 1200px;
		--equipment-gutter: 1em;
	}

	body {
		background: white !important;
		background-size: auto !important;
	}

	.dark body {
		background: rgb(17, 24, 39) !important;
	}
</style>

<style>
	.hero-split,
	.equipment-main {
		box-sizing: border-box;
		width: min(100%, var(--equipment-max-width));
		margin: 0 auto;
		padding-inline: var(--equipment-gutter);
	}

	.hero-split {
		padding-block: 2rem 1.5rem;
	}

	.hero-split__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.hero-split__media {
		order: 1;
	}

	.hero-split__image {
		width: 100%;
		display: block;
		border-radius: 1rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
		aspect-ratio: 4 / 3;
		object-fit: cover;
		background: rgba(0, 0, 0, 0.05);
	}

	:global(.dark) .hero-split__image {
		border-color: rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.05);
	}

	.hero-split__content {
		order: 2;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.hero-split__kicker {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.6);
	}

	:global(.dark) .hero-split__kicker {
		color: rgba(255, 255, 255, 0.6);
	}

	.hero-split__title {
		font-size: clamp(1.9rem, 2.6vw, 2.5rem);
		line-height: 1.2;
		font-weight: 600;
		margin: 0;
	}

	.hero-split__intro {
		color: rgba(0, 0, 0, 0.7);
		max-width: 65ch;
		margin: 0;
	}

	:global(.dark) .hero-split__intro {
		color: rgba(255, 255, 255, 0.7);
	}

	.hero-split__nav {
		padding-top: 0.25rem;
	}

	.hero-split__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.hero-split__chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		border: 1px solid rgba(0, 0, 0, 0.1);
		font-size: 0.85rem;
		color: rgba(0, 0, 0, 0.8);
		text-decoration: none;
		transition: background 0.2s ease;
	}

	.hero-split__chip:hover {
		background: rgba(0, 0, 0, 0.05);
	}

	:global(.dark) .hero-split__chip {
		border-color: rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.8);
	}

	:global(.dark) .hero-split__chip:hover {
		background: rgba(255, 255, 255, 0.05);
	}

	@media (min-width: 1024px) {
		.hero-split__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			align-items: center;
			gap: 2.5rem;
		}
	}

	.equipment-main {
		padding-block: 1rem 4em;
	}

	.equipment-page {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.equipment-section {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.section-intro {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 1rem;
	}

	:global(.dark) .section-intro {
		color: rgb(var(--gray));
	}

	.equipment-section h2 {
		font-size: 1.8rem;
		margin-bottom: 0.25rem;
	}

	@media (max-width: 768px) {
		.page-header h1 {
			font-size: 2rem;
		}
		.equipment-section h2 {
			font-size: 1.5rem;
		}
	}
</style>
